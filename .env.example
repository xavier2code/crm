# 生产环境环境变量配置
# 复制为 .env 后修改实际值

# 数据库
DB_PASSWORD=your_secure_password_here

# JWT Secret：必须 >= 32 字节
JWT_SECRET=your-32-byte-or-longer-secret-key-replace-this

# JWT 签发者
JWT_ISSUER=crm-cy

# Redis（留空则不启用密码认证）
REDIS_PASSWORD=

# 文件存储路径（Docker 环境下由 docker-compose 设置，本地开发可不填）
FILE_STORAGE_PATH=./data/uploads

# 日志路径（Docker 环境下由 docker-compose 设置，本地开发可不填）
LOG_PATH=./logs
# 生产环境环境变量配置
# 复制为 .env 后修改实际值

# 数据库
DB_PASSWORD=your_secure_password_here

# JWT Secret：必须 >= 32 字节
JWT_SECRET=your-32-byte-or-longer-secret-key-replace-this

# 可选：JWT 签发者
JWT_ISSUER=crm-cy
